<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Heesch Studio: Shape Maker v1.0</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            font-family: sans-serif;
            background: #1e1e24;
            color: #e0e0e0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        canvas {
            background: #111;
            border: 2px solid #444;
            cursor: crosshair;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .controls {
            margin-top: 15px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
            background: #2b6cb0;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        button:hover { background: #3182ce; }
    </style>
</head>
<body>

    <h1>Heeschometric Shape Maker</h1>
    <p>Click to add vertices. Click the first point again (or press Clear) to reset.</p>
    
    <canvas id="studioCanvas" width="600" height="600"></canvas>
    
    <div class="controls">
        <button id="clearBtn">Clear Shape</button>
    </div>

<script>
const canvas = document.getElementById('studioCanvas');
const ctx = canvas.getContext('2d');
const clearBtn = document.getElementById('clearBtn');

// THIS IS YOUR FOUNDATION: A clean array of (x, y) vertices
let vertices = [];
const SNAP_DIST = 15; // Pixels away from origin to trigger a closed polygon

// Event listener for user mouse clicks
canvas.addEventListener('click', (e) => {
    // Get mouse coordinates relative to the canvas bounding box
    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;

    // Check if the user is clicking close to the starting vertex to close/reset the loop
    if (vertices.length > 2) {
        const startX = vertices[0].x;
        const startY = vertices[0].y;
        const dist = Math.hypot(mouseX - startX, mouseY - startY);
        
        if (dist < SNAP_DIST) {
            console.log("Shape Complete! Exporting Vertex Array: ", JSON.stringify(vertices));
            alert("Shape Data Captured! Ready for the Grid lattice.");
            vertices = []; // Clear to start a new shape
            draw();
            return;
        }
    }

    // Push new clean coordinate tracking object into our data structure
    vertices.push({ x: mouseX, y: mouseY });
    draw();
});

// Clear button handler
clearBtn.addEventListener('click', () => {
    vertices = [];
    draw();
});

// Pure rendering routine
function draw() {
    // Clear the slate
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Draw background guide lines (Grid layout placeholder)
    ctx.strokeStyle = '#222';
    ctx.lineWidth = 1;
    for(let i = 0; i < canvas.width; i += 40) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    if (vertices.length === 0) return;

    // 1. Draw lines connecting active points
    ctx.strokeStyle = '#4299e1';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(vertices[0].x, vertices[0].y);
    for (let i = 1; i < vertices.length; i++) {
        ctx.lineTo(vertices[i].x, vertices[i].y);
    }
    ctx.stroke();

    // 2. Draw the tracking node points
    vertices.forEach((vertex, index) => {
        ctx.fillStyle = index === 0 ? '#f56565' : '#48bb78'; // Red for origin point, Green for others
        ctx.beginPath();
        ctx.arc(vertex.x, vertex.y, 6, 0, 2 * Math.PI);
        ctx.fill();
    });
}
</script>
</body>
</html>
