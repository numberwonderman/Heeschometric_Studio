<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Heeschetric Studio: CCCC Constraint Engine</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            font-family: sans-serif;
            background: #1e1e24;
            color: #e0e0e0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        canvas {
            background: #111;
            border: 2px solid #444;
            cursor: crosshair;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .controls {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        #clearBtn { background: #e53e3e; }
        #clearBtn:hover { background: #c53030; }
        #generateBtn { background: #48bb78; }
        #generateBtn:hover { background: #38a169; }
    </style>
</head>
<body>

    <h1>Heeschometric Studio: CCCC Type</h1>
    <p>Click points to draw <b>Edge 1</b>. Hit "Enforce CCCC Constraints" to generate a mathematically perfect Heesch tile!</p>
    
    <canvas id="studioCanvas" width="600" height="600"></canvas>
    
    <div class="controls">
        <button id="generateBtn">Enforce CCCC Constraints</button>
        <button id="clearBtn">Clear Canvas</button>
    </div>

<script>
const canvas = document.getElementById('studioCanvas');
const ctx = canvas.getContext('2d');
const clearBtn = document.getElementById('clearBtn');
const generateBtn = document.getElementById('generateBtn');

let masterEdge = []; // The single base curve drawn by the user
let completeTile = []; // Stores the 4 constrained sides combined
let isConstrained = false;

// --- HEESCH CENTER-ROTATION MATRIX UTILITY ---
// Rotates a line segment 180 degrees around a specific midpoint
function rotate180Around(points, midX, midY) {
    return points.map(p => ({
        x: 2 * midX - p.x,
        y: 2 * midY - p.y
    })).reverse(); // Reverse array order to keep polygon vertex winding contiguous
}

canvas.addEventListener('click', (e) => {
    if (isConstrained) return; // Lock drawing once constraints are computed

    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;

    masterEdge.push({ x: mouseX, y: mouseY });
    draw();
});

generateBtn.addEventListener('click', () => {
    if (masterEdge.length < 2) {
        alert("Click at least two points to define your base edge!");
        return;
    }

    // Define fixed target vertices for our structural Quad lattice corner layout
    const p0 = masterEdge[0];                       // Bottom Left corner
    const p1 = masterEdge[masterEdge.length - 1];    // Bottom Right corner
    
    // Scale vectors to construct an orthogonal grid framework for the remaining 2 corners
    const dx = p1.x - p0.x;
    const dy = p1.y - p0.y;
    
    const p2 = { x: p1.x - dy, y: p1.y + dx };       // Top Right corner
    const p3 = { x: p0.x - dy, y: p0.y + dx };       // Top Left corner

    // --- CONSTRUCT SIDE 1 (User Drawn Curve) ---
    const side1 = [...masterEdge];

    // --- CONSTRUCT SIDE 2 (Rotated copy of side 1 shifted to Edge 2) ---
    const mid2 = { x: (p1.x + p2.x) / 2, y: (p1.y + p2.y) / 2 };
    const side2 = rotate180Around(side1, mid2.x, mid2.y);

    // --- CONSTRUCT SIDE 3 (Rotated copy of side 1 shifted to Edge 3) ---
    const mid3 = { x: (p2.x + p3.x) / 2, y: (p2.y + p3.y) / 2 };
    const side3 = rotate180Around(side1, mid3.x, mid3.y);

    // --- CONSTRUCT SIDE 4 (Rotated copy of side 1 shifted to Edge 4) ---
    const mid4 = { x: (p3.x + p0.x) / 2, y: (p3.y + p0.y) / 2 };
    const side4 = rotate180Around(side1, mid4.x, mid4.y);

    // Combine all 4 points matrices cleanly into a closed system loop
    completeTile = [...side1, ...side2, ...side3, ...side4];
    isConstrained = true;
    draw();
});

clearBtn.addEventListener('click', () => {
    masterEdge = [];
    completeTile = [];
    isConstrained = false;
    draw();
});

function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Grid Background Layout lines
    ctx.strokeStyle = '#25252d';
    ctx.lineWidth = 1;
    for(let i = 0; i < canvas.width; i += 40) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    // Render Full Enforced Heesch CCCC Tile
    if (isConstrained && completeTile.length > 0) {
        ctx.strokeStyle = '#38a169'; // Green indicating passing structural constraint validation
        ctx.lineWidth = 4;
        ctx.beginPath();
        ctx.moveTo(completeTile[0].x, completeTile[0].y);
        for(let i = 1; i < completeTile.length; i++) ctx.lineTo(completeTile[i].x, completeTile[i].y);
        ctx.closePath();
        ctx.stroke();
        
        // Fill inside lightly to show it as a solid proto-tile
        ctx.fillStyle = 'rgba(56, 161, 105, 0.15)';
        ctx.fill();
        return; 
    }

    // Render active Master Reference Line while user is drawing
    if (masterEdge.length > 0) {
        ctx.strokeStyle = '#4299e1'; // Blue tracking color
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.moveTo(masterEdge[0].x, masterEdge[0].y);
        for (let i = 1; i < masterEdge.length; i++) ctx.lineTo(masterEdge[i].x, masterEdge[i].y);
        ctx.stroke();

        masterEdge.forEach((vertex, idx) => {
            ctx.fillStyle = idx === 0 ? '#f56565' : '#4299e1';
            ctx.beginPath();
            ctx.arc(vertex.x, vertex.y, 5, 0, 2 * Math.PI);
            ctx.fill();
        });
    }
}
</script>
</body>
</html>
