<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Heeschometric Studio v1.1</title>
    <style>
        body {
            margin: 0;
            padding: 20px;
            font-family: sans-serif;
            background: #1e1e24;
            color: #e0e0e0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        canvas {
            background: #111;
            border: 2px solid #444;
            cursor: crosshair;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }
        .controls {
            margin-top: 15px;
            display: flex;
            gap: 10px;
        }
        button {
            padding: 10px 20px;
            font-size: 16px;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        #clearBtn { background: #e53e3e; }
        #clearBtn:hover { background: #c53030; }
        #testBtn { background: #2b6cb0; }
        #testBtn:hover { background: #2b6cb0; }
    </style>
</head>
<body>

    <h1>Heeschometric Studio</h1>
    <p>Click to add vertices. Close the shape by clicking the red starting point, then hit "Generate Cluster".</p>
    
    <canvas id="studioCanvas" width="600" height="600"></canvas>
    
    <div class="controls">
        <button id="testBtn">Generate Cluster</button>
        <button id="clearBtn">Clear Studio</button>
    </div>

<script>
const canvas = document.getElementById('studioCanvas');
const ctx = canvas.getContext('2d');
const clearBtn = document.getElementById('clearBtn');
const testBtn = document.getElementById('testBtn');

let vertices = [];
let transformedClones = []; // Stores generated layers/clones for rendering
let isShapeClosed = false;
const SNAP_DIST = 15;

// --- THE MATRICES & TRANSFORMATION ENGINE ---
// Pure geometric function applying affine transformations to your vertex array
function cloneShape(shapeVertices, tx, ty, angleDegrees, reflectX = false) {
    const angleRad = (angleDegrees * Math.PI) / 180;
    const cos = Math.cos(angleRad);
    const sin = Math.sin(angleRad);

    return shapeVertices.map(v => {
        // 1. Apply reflection if flagged
        let x1 = reflectX ? -v.x : v.x;
        let y1 = v.y;

        // 2. Rotate around the local origin
        let x2 = x1 * cos - y1 * sin;
        let y2 = x1 * sin + y1 * cos;

        // 3. Translate to target coordinate destination
        return {
            x: x2 + tx,
            y: y2 + ty
        };
    });
}

canvas.addEventListener('click', (e) => {
    if (isShapeClosed) return; // Prevent adding points if shape is locked

    const rect = canvas.getBoundingClientRect();
    const mouseX = e.clientX - rect.left;
    const mouseY = e.clientY - rect.top;

    if (vertices.length > 2) {
        const dist = Math.hypot(mouseX - vertices[0].x, mouseY - vertices[0].y);
        if (dist < SNAP_DIST) {
            isShapeClosed = true;
            draw();
            return;
        }
    }

    vertices.push({ x: mouseX, y: mouseY });
    draw();
});

// Button triggers the search/transformation matrix sandbox
testBtn.addEventListener('click', () => {
    if (vertices.length < 3 || !isShapeClosed) {
        alert("Please draw and close a valid polygon shape first!");
        return;
    }

    // Capture the geometric center of your drawn shape to rotate smoothly around it
    const centerX = vertices.reduce((sum, v) => sum + v.x, 0) / vertices.length;
    const centerY = vertices.reduce((sum, v) => sum + v.y, 0) / vertices.length;

    // Shift original shape vertices to center origin momentarily for accurate rotation
    const localizedVertices = vertices.map(v => ({ x: v.x - centerX, y: v.y - centerY }));

    transformedClones = [
        // Clone 1: Shifted right, rotated 60 degrees
        cloneShape(localizedVertices, centerX + 120, centerY, 60, false),
        // Clone 2: Shifted left, rotated 120 degrees
        cloneShape(localizedVertices, centerX - 120, centerY, 120, false),
        // Clone 3: Shifted down-right, reflected across X axis
        cloneShape(localizedVertices, centerX + 60, centerY + 100, 180, true),
        // Clone 4: Shifted up-left, rotated 240 degrees
        cloneShape(localizedVertices, centerX - 60, centerY - 100, 240, false)
    ];

    draw();
});

clearBtn.addEventListener('click', () => {
    vertices = [];
    transformedClones = [];
    isShapeClosed = false;
    draw();
});

// Render Loop
function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Draw background guide grid lines
    ctx.strokeStyle = '#25252d';
    ctx.lineWidth = 1;
    for(let i = 0; i < canvas.width; i += 40) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, canvas.height); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(canvas.width, i); ctx.stroke();
    }

    // Render Cloned Transformation Layer
    transformedClones.forEach((clone, idx) => {
        ctx.strokeStyle = `hsl(${(idx * 75) % 360}, 70%, 60%)`; // Distinct color profiles
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(clone[0].x, clone[0].y);
        for(let i = 1; i < clone.length; i++) ctx.lineTo(clone[i].x, clone[i].y);
        ctx.closePath();
        ctx.stroke();
    });

    if (vertices.length === 0) return;

    // Render Master Proto-Tile
    ctx.strokeStyle = isShapeClosed ? '#48bb78' : '#4299e1'; // Green if closed, blue if drawing
    ctx.lineWidth = 4;
    ctx.beginPath();
    ctx.moveTo(vertices[0].x, vertices[0].y);
    for (let i = 1; i < vertices.length; i++) ctx.lineTo(vertices[i].x, vertices[i].y);
    
    if (isShapeClosed) ctx.closePath();
    ctx.stroke();

    // Draw active vertices tracking nodes
    vertices.forEach((vertex, index) => {
        ctx.fillStyle = index === 0 ? '#f56565' : '#48bb78';
        ctx.beginPath();
        ctx.arc(vertex.x, vertex.y, index === 0 ? 7 : 5, 0, 2 * Math.PI);
        ctx.fill();
    });
}
</script>
</body>
</html>
